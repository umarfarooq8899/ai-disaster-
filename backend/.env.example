# ─────────────────────────────────────────────────
# ENVIRONMENT VARIABLES — Copy to `.env` and fill in your values.
# NEVER commit the actual `.env` file to version control!
# ─────────────────────────────────────────────────

# MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secret for signing authentication tokens (use a long random string)
JWT_SECRET=<your_jwt_secret_here>

# Cloudinary — for media uploads (images/videos)
CLOUDINARY_CLOUD_NAME=<your_cloud_name>
CLOUDINARY_API_KEY=<your_api_key>
CLOUDINARY_API_SECRET=<your_api_secret>

# Google OAuth
GOOGLE_CLIENT_ID=<your_google_client_id>
GOOGLE_CLIENT_SECRET=<your_google_client_secret>

# Admin Seeder — credentials for the initial admin accounts
# Set these before running: node backend/seeders/adminSeeder.js
ADMIN_1_NAME=Umar Farooq
ADMIN_1_EMAIL=<admin1_email>
ADMIN_1_PASSWORD=<admin1_strong_password>

ADMIN_2_NAME=Nimra Imran
ADMIN_2_EMAIL=<admin2_email>
ADMIN_2_PASSWORD=<admin2_strong_password>

ADMIN_3_NAME=Anum
ADMIN_3_EMAIL=<admin3_email>
ADMIN_3_PASSWORD=<admin3_strong_password>
